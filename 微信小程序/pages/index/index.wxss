/* ========== 导航栏 ========== */
.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: rgba(255,255,255,0.95);
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
}
.logo {
  font-size: 32rpx;
  font-weight: 700;
  color: #e67e22;
  letter-spacing: 2rpx;
}
.cta-btn {
  background: #e67e22;
  color: white;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* ========== 头部大图 ========== */
.hero {
  margin-top: 88rpx;
  min-height: 85vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 80rpx 48rpx;
  background: linear-gradient(160deg, #fff5eb 0%, #fce4cc 30%, #ffe0b2 60%, #fffaf5 100%);
}
.hero-content { max-width: 700rpx; }
.hero-badge {
  display: inline-block;
  background: #e67e22;
  color: white;
  padding: 10rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  margin-bottom: 40rpx;
}
.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #2d2d2d;
  line-height: 1.3;
  margin-bottom: 24rpx;
}
.accent { color: #e67e22; }
.subtitle {
  font-size: 30rpx;
  color: #5a5a5a;
  margin-bottom: 20rpx;
  line-height: 1.6;
  display: block;
}
.years-badge {
  display: inline-flex;
  align-items: center;
  color: #c96b15;
  font-weight: 700;
  font-size: 28rpx;
  margin-bottom: 48rpx;
  background: rgba(230,126,34,0.1);
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
}
.hero-buttons { display: flex; gap: 24rpx; }
.btn {
  padding: 24rpx 48rpx;
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.btn-primary {
  background: #e67e22;
  color: white;
  box-shadow: 0 12rpx 48rpx rgba(230,126,34,0.35);
}
.btn-outline {
  background: white;
  color: #e67e22;
  border: 3rpx solid #e67e22;
}

/* ========== 通用区域 ========== */
.section {
  padding: 80rpx 40rpx;
  max-width: 750rpx;
  margin: 0 auto;
}
.section-label {
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #e67e22;
  margin-bottom: 16rpx;
}
.section-title {
  text-align: center;
  font-size: 44rpx;
  font-weight: 800;
  color: #2d2d2d;
  margin-bottom: 24rpx;
  line-height: 1.4;
}
.section-desc {
  text-align: center;
  color: #7a7a7a;
  font-size: 28rpx;
  max-width: 600rpx;
  margin: 0 auto 60rpx;
  line-height: 1.7;
}
.bg-alt { background: #fff5eb; }

/* ========== 关于我们 ========== */
.about-text {
  font-size: 30rpx;
  color: #5a5a5a;
  line-height: 2;
  text-align: center;
  max-width: 650rpx;
  margin: 0 auto;
}
.strong { font-weight: 700; color: #2d2d2d; }
.about-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
  margin-top: 50rpx;
  text-align: center;
}
.stat-item { padding: 30rpx; }
.stat-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #e67e22;
  line-height: 1.1;
}
.stat-label {
  font-size: 24rpx;
  color: #7a7a7a;
  margin-top: 8rpx;
}

/* ========== 三大亮点 ========== */
.highlights {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.highlight-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  text-align: center;
}
.highlight-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.highlight-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d2d2d;
  margin-bottom: 12rpx;
}
.highlight-desc {
  font-size: 26rpx;
  color: #7a7a7a;
  line-height: 1.7;
  display: block;
}

/* ========== 菜品轮播 ========== */
.food-swiper {
  width: 100%;
  height: 500rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.food-img {
  width: 100%;
  height: 500rpx;
}
.food-hint {
  text-align: center;
  color: #bbb;
  font-size: 24rpx;
  margin-top: 24rpx;
}

/* ========== 聚餐时光 ========== */
.gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.gallery-img {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
}

/* ========== 价格方案 ========== */
.pricing-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.price-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  text-align: center;
}
.price-title {
  font-size: 36rpx;
  margin-bottom: 16rpx;
}
.price-amount {
  font-size: 60rpx;
  font-weight: 800;
  color: #e67e22;
  margin-bottom: 20rpx;
}
.price-unit { font-size: 28rpx; font-weight: 400; color: #7a7a7a; }
.price-list {
  font-size: 26rpx;
  color: #5a5a5a;
  line-height: 2.2;
}
.discount-tip {
  text-align: center;
  margin-top: 36rpx;
  color: #7a7a7a;
  font-size: 26rpx;
}
.orange-text { color: #e67e22; font-weight: 700; }

/* ========== 联系方式 ========== */
.contact-grid {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.contact-info {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}
.contact-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}
.contact-item {
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #5a5a5a;
  line-height: 1.8;
  display: flex;
  align-items: flex-start;
}
.contact-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}
.qr-box {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}
.qr-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}
.qr-img {
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto;
  display: block;
}
.qr-tip {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 20rpx;
  display: block;
}

/* ========== 页脚 ========== */
.footer {
  text-align: center;
  padding: 40rpx;
  color: #bbb;
  font-size: 22rpx;
  background: #2d2d2d;
}

/* ========== 返回顶部 ========== */
.back-to-top {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e67e22;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(230,126,34,0.4);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  z-index: 999;
}
.back-to-top.visible {
  opacity: 1;
  pointer-events: auto;
}

/* ========== 底部固定栏 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  border-top: 1rpx solid rgba(0,0,0,0.08);
  padding: 12rpx 40rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  gap: 24rpx;
  z-index: 1000;
}
.bottom-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.bottom-btn-call {
  background: #e67e22;
  color: white;
}
.bottom-btn-wechat {
  background: #07c160;
  color: white;
}
